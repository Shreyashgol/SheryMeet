# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=meeting-intelligence-pipeline
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_JSON=true

# ── API ─────────────────────────────────────────────────────────────────────--
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed browser origins (do NOT use "*" in production).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Uploads ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=209715200
ALLOWED_AUDIO_FORMATS=wav,mp3

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=/data/audio

# ── Database (Neon serverless Postgres) ───────────────────────────────────────
# Paste your Neon connection string. Change the scheme to postgresql+psycopg2://
# and keep ?sslmode=require. Prefer the pooled host (contains "-pooler").
#   postgresql+psycopg2://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=

# ── Redis / Celery ────────────────────────────────────────────────────────────
# localhost for bare-metal runs; docker overrides to redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
# Leave broker/result backend empty to reuse REDIS_URL.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Run the pipeline INLINE in the API process (no broker/worker). Set true on
# constrained hosts like Render's free tier; keep false for real async ops.
CELERY_TASK_ALWAYS_EAGER=false

# ── ASR ───────────────────────────────────────────────────────────────────────
# Provider: local_whisper | groq_whisper | openai_whisper | mock
# groq_whisper reuses GROQ_API_KEY / GROQ_BASE_URL (set in the LLM section).
ASR_PROVIDER=local_whisper
ASR_MODEL=base                                   # local_whisper size
GROQ_WHISPER_MODEL=whisper-large-v3-turbo        # groq_whisper model id
ASR_LANGUAGE=
ASR_TIMEOUT_SECONDS=1200
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8

# ── LLM ────────────────────────────────────────────────────────────────────────
# Provider: claude | openai | gemini | groq | mock
LLM_PROVIDER=claude
LLM_MODEL=claude-opus-4-8
LLM_TIMEOUT_SECONDS=120
LLM_MAX_OUTPUT_TOKENS=4096
LLM_TEMPERATURE=0.2
# Groq is OpenAI-compatible; override only if needed.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Secrets (never commit real keys) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Resilience ────────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_BASE_SECONDS=2.0
RETRY_BACKOFF_MAX_SECONDS=30.0
