# Root env — OPTIONAL. Used only for docker-compose interpolation of the worker
# concurrency knobs below. All real backend config (Neon DATABASE_URL, provider
# keys, ASR/LLM selection) lives in backend/.env; frontend config in frontend/.env.
#
# Copy to .env if you want to tune concurrency; otherwise the defaults apply.

API_WORKERS=2
AUDIO_CONCURRENCY=1
TRANSCRIPT_CONCURRENCY=2
SUMMARY_CONCURRENCY=2
CHECKLIST_CONCURRENCY=2
